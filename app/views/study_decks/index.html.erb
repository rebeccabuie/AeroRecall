<section class="page-hero">
  <p class="eyebrow">Private Pilot Study App</p>
  <h1>AeroRecall</h1>
  <p>Study aviation topics with visual boards, quick quizzes, and instant feedback.</p>
</section>

<section class="deck-grid home-deck-grid">
  <% @study_decks.each do |deck| %>
      <%= link_to study_deck_path(deck), class: "deck-card home-deck-card deck-#{deck.name.parameterize}" do %>      <p class="eyebrow">Study Deck</p>
      <h2><%= deck.name %></h2>

      <div class="home-deck-icon">
        <% deck_image =
          case deck.name
          when "Weather"
            "weather-deck-cloud.png"
          when "Rules & Regulations"
            "rules-and-regs-deck.png"
          else
            "weather-deck-cloud.png"
          end
        %>

        <%= image_tag deck_image, class: "deck-card-image" %>
      </div>

      <p><%= deck.description %></p>

      <% if authenticated? %>
        <% progress = @deck_progress[deck.id] %>

        <div class="progress-bar">
          <div
            class="progress-bar-fill"
            style="width: <%= progress[:percentage] %>%"
          ></div>
        </div>

        <p><%= progress[:percentage] %>% Complete</p>
      <% end %>

      <span>Start studying →</span>
    <% end %>
  <% end %>
</section>