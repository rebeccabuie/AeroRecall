<section class="study-card-page">
<header class="deck-hero deck-hero">
  <div class="deck-hero-left">
    <%= image_tag "weather-deck-cloud.png", class: "deck-hero-image", alt: "Weather cloud" %>

    <div>
      <p class="deck-hero-eyebrow">Study Deck</p>
      <h1><%= @study_deck.name %></h1>
      <p><%= @study_deck.description %></p>
    </div>
  </div>

  <% if authenticated? %>
    <div class="deck-hero-actions">
      <% completed_cards = @study_card_progresses.values.count(&:completed?) %>
      <% total_cards = @study_deck.study_cards.count %>
      <% remaining_cards = total_cards - completed_cards %>

      <p><%= remaining_cards %>/<%= total_cards %> Cards Remaining</p>

      <% continue_card =
           @study_deck.first_incomplete_card_for(Current.user) ||
           @study_deck.study_cards.order(:position).first %>

      <%= link_to "Continue Studying ✈️",
                  study_card_path(continue_card),
                  class: "deck-hero-link" %>
    </div>
  <% end %>
</header>

<div class="deck-progress-card">
  <div class="progress-row">
    <div class="deck-progress-bar">
      <div
        class="deck-progress-fill"
        style="width: <%= @deck_progress_percentage %>%;"
      ></div>
    </div>

    <span class="progress-percent">
      <%= @deck_progress_percentage %>%
    </span>
  </div>

  <p class="deck-progress-text">
    <%= @completed_cards_count %> of <%= @total_cards_count %> cards completed
  </p>
</div>

  <% if authenticated? && @deck_progress_percentage == 100 %>
    <section class="deck-complete-card">
      <p class="deck-complete-eyebrow">Deck Complete</p>
      <h2>Weather Deck Complete! 🎉</h2>
      <p>
        You completed all <%= @total_cards_count %> lessons in this deck.
        Nice work!
      </p>
    </section>
  <% end %>

  <% if authenticated? && @deck_progress_percentage == 100 %>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>

    <script>
      confetti({
        particleCount: 140,
        spread: 90,
        origin: { y: 0.6 }
      });
    </script>
  <% end %>

  <section class="deck-grid">
    <% @study_deck.study_cards.order(:position).each do |card| %>
      <%= link_to study_card_path(card), class: "lesson-card" do %>
        <% if card.infographic.attached? %>
          <%= image_tag card.infographic, class: "card-thumbnail" %>
        <% end %>
        <div class="deck-card-content">
          <p class="eyebrow">Card <%= card.position %></p>
          <h2><%= card.title %></h2>
          <p><%= card.description %></p>

                <% if authenticated? %>
                  <% progress = @study_card_progresses[card.id] %>

                  <% if progress.present? %>
                    <% percent_complete = ((progress.questions_answered.to_f / card.questions.count) * 100).round %>

                    <div class="lesson-status-row">
                      <% if progress.completed? %>
                        <p class="status-pill status-completed">Completed</p>
                      <% elsif progress.questions_answered.zero? %>
                        <p class="status-pill status-not-started">Not Started</p>
                      <% else %>
                        <p class="status-pill status-in-progress">In Progress</p>
                      <% end %>

                      <span class="lesson-score">
                        Score: <%= progress.correct_answers %> / <%= card.questions.count %>
                      </span>
                    </div>

                    <div class="progress-row">
                      <div class="progress-bar">
                        <div
                          class="progress-bar-fill"
                          style="width: <%= percent_complete %>%"
                        ></div>
                      </div>

                      <span class="progress-percent">
                        <%= percent_complete %>%
                      </span>
                    </div>

                  <% else %>
                    <p class="status-pill status-not-started">Not Started</p>
                  <% end %>

                <% end %>
              </div>

            <span class="lesson-button">
              Start Lesson ✈️
            </span>
        </div>
      <% end %>
    <% end %>
  </section>
  <%= link_to "← Back to Decks", root_path, class: "deck-page-back-button" %>
</section>
