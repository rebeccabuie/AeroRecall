<section class="study-card-page">
  <header class="study-card-header">
    <div class="title-row">
      <h1><%= @study_deck.name %></h1>
      <p class="card-progress">
        <%= @study_deck.study_cards.count %> Cards
      </p>
    </div>
    <p><%= @study_deck.description %></p>

    <% if authenticated? %>
      <% continue_card =
          @study_deck.first_incomplete_card_for(Current.user) ||
          @study_deck.study_cards.order(:position).first %>

      <%= link_to "Continue Studying →",
                  study_card_path(continue_card),
                  class: "button" %>

      <% completed_cards = @study_card_progresses.values.count(&:completed?) %>
      <% total_cards = @study_deck.study_cards.count %>
      <% remaining_cards = total_cards - completed_cards %>

      <p class="deck-progress-summary">
        <%= remaining_cards %> / <%= total_cards %> Cards Remaining
      </p>
    <% end %>

  </header>

  <section class="deck-grid">
    <% @study_deck.study_cards.order(:position).each do |card| %>
      <%= link_to study_card_path(card), class: "lesson-card" do %>
        <% if card.infographic.attached? %>
          <%= image_tag card.infographic, class: "card-thumbnail" %>
        <% end %>
        <div class="deck-card-content">
          <p class="eyebrow">Card <%= card.position %></p>
          <h2><%= card.title %></h2>
          <p><%= card.description %></p>

          <% if authenticated? %>
            <% progress = @study_card_progresses[card.id] %>

            <% if progress.present? %>
              <% percent_complete = ((progress.questions_answered.to_f / card.questions.count) * 100).round %>

              <% if progress.completed? %>
                <p>✅ Completed</p>
              <% else %>
                <p>📚 In Progress</p>
              <% end %>

              <div class="progress-bar">
                <div
                  class="progress-bar-fill"
                  style="width: <%= percent_complete %>%"
                ></div>
              </div>

              <p><%= percent_complete %>% Complete</p>

            <% else %>
              <p>Not Started</p>
            <% end %>

            <% end %>

            <span>Start lesson →</span>
        </div>
      <% end %>
    <% end %>
  </section>
  <%= link_to "← Back to Decks", root_path, class: "back-link" %>
</section>
